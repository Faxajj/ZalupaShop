<%- include('../partials/header') %>
<h1><%= product ? 'Редактировать товар' : 'Добавить товар' %></h1>
<% if (error) { %><p class="error"><%= error %></p><% } %>
<form method="post" action="<%= action %>" enctype="multipart/form-data" class="form">
  <label>Название <input type="text" name="name" value="<%= product?.name || '' %>" required /></label>
  <label>Цена <input type="number" step="0.01" name="price" value="<%= product?.price || '' %>" required /></label>
  <label>Описание <textarea name="description" rows="4"><%= product?.description || '' %></textarea></label>
  <label>Категория <input type="text" name="category" value="<%= product?.category || '' %>" /></label>
  <label>Артикул <input type="text" name="article" value="<%= product?.article || '' %>" /></label>
  <label>Характеристики JSON
    <textarea name="specs" rows="6"><%= product?.specs || '{"Бренд":"","Модель":""}' %></textarea>
  </label>
  <label>Фото (до 3 файлов)
    <input type="file" name="images" multiple accept="image/*" />
  </label>
  <button class="btn" type="submit">Сохранить</button>
</form>

<% if (images && images.length) { %>
  <h3>Текущие фото</h3>
  <div class="gallery">
    <% images.forEach((img) => { %>
      <div class="image-box">
        <img src="<%= img.image_path %>" alt="product image" />
        <form method="post" action="/admin/products/<%= product.id %>/images/<%= img.id %>/delete">
          <button class="btn btn-small danger" type="submit">Удалить фото</button>
        </form>
      </div>
    <% }) %>
  </div>
<% } %>
<%- include('../partials/footer') %>
