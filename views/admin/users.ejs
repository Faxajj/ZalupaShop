<%- include('../partials/header') %>
<h1>Пользователи</h1>
<table class="table">
  <thead><tr><th>ID</th><th>Email</th><th>Роль</th><th>Действия</th></tr></thead>
  <tbody>
    <% users.forEach((u) => { %>
      <tr>
        <td><%= u.id %></td>
        <td><%= u.email %></td>
        <td><%= u.role %></td>
        <td class="actions">
          <form method="post" action="/admin/users/<%= u.id %>/role" class="inline-form">
            <select name="role">
              <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>user</option>
              <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>admin</option>
            </select>
            <button class="btn btn-small" type="submit">Сменить</button>
          </form>
          <form method="post" action="/admin/users/<%= u.id %>/delete" class="inline-form">
            <button class="btn btn-small danger" type="submit">Удалить</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include('../partials/footer') %>
